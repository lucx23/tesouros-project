<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tesouros da Igreja</title>
    <link rel="stylesheet" href="/public/css/style.css">
    <link
        href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300..700&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Oswald:wght@200..700&family=Pacifico&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
        rel="stylesheet">
    <link
        href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300..700&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Libre+Bodoni:ital,wght@0,400..700;1,400..700&family=Oswald:wght@200..700&family=Pacifico&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
        rel="stylesheet">

    <style>
        * {
            padding: 0;
            margin: 0;
            box-sizing: border-box;
        }

        :root {
            --vermelho: #8B0000;
            --bege: #FAF3E0;
            --dourado: #C9A86A;
            --marrom: #4E342E;
            --branco: #FFFFFF;

            --fonte1: 'Inter', sans-serif;
            --fonte2: 'Libre Bodoni', sans-serif;
            --fonte3: 'Poppins', sans-serif;


        }

        body {
            font-family: Arial, Helvetica, sans-serif;
            background-color: var(--dourado);
        }

        header {
            display: flex;
            justify-content: space-around;
            align-items: center;
            /* margin: auto; */
            padding: 1rem;
            background-color: var(--marrom);
            color: var(--dourado);

            & h1 {
                & a {
                    color: var(--dourado);
                    text-decoration: none;
                    /* font-size: 1.5rem; */
                    font-weight: bold;
                }
                font-family: var(--fonte2);
            }

            & nav {
                display: flex;
                gap: 20px;
                padding: 20px;

                & ul {
                    display: flex;
                    gap: 20px;
                    list-style: none;
                    gap: 5.5rem;
                }


                & a {
                    text-decoration: none;
                    font-weight: bold;
                    font-size: 18px;
                    color: var(--dourado);
                }
            }
        }

        main h1 {
            text-align: center;
            margin: 20px 0;
            font-family: var(--fonte2);
        }

        .botoes-explorar {
            display: flex;
            justify-content: center;
            margin-top: 20px;

            & .btn {
                padding: 10px 20px;
                background-color: var(--marrom);
                color: var(--dourado);
                text-decoration: none;
                font-weight: bold;
                border-radius: 4px;
                transition: 250ms;

                &:hover {
                    transform: scale(1.1);
                }
            }
        }

        .santos {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 20px;
            padding: 20px;
        }

        .santo {
            background-color: #ececec;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            width: 300px;
            padding: 20px;
            text-align: center;
            display: flex;
            flex-direction: column;
            gap: .5rem;

            & img {
                width: 100%;
                height: 200px;
                border-radius: 8px;
            }

            & p {
                text-align: justify;
            }

            & h3 {
                color: var(--dourado);
                font-family: var(--fonte2);
            }

            & a {
                padding: 10px;
                background-color: var(--marrom);
                color: var(--dourado);
                border: none;
                border-radius: 4px;
                cursor: pointer;
                font-weight: bold;
                width: 50%;
                margin: auto;
                transition: 250ms;
                text-decoration: none;

                &:hover {
                    transform: scale(1.1);
                }
            }
        }

        .pagina-santo {
            max-width: 600px;
            margin: 20px auto;
            background-color: #ececec;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);

            & h1 {
                text-align: center;
                color: var(--dourado);
                font-family: var(--fonte2);
            }

            & img {
                width: 100%;
                height: auto;
                border-radius: 8px;
                margin-top: 20px;
            }

            & p {
                margin-top: 20px;
                text-align: justify;
                line-height: 1.6;
            }
        }

        .form-login {
            max-width: 400px;
            margin: 20px auto;
            background-color: #ececec;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            display: flex;
            flex-direction: column;
            gap: 15px;

            & h2 {
                text-align: center;
                color: var(--dourado);
                font-family: var(--fonte2);
            }

            & form {
                display: flex;
                flex-direction: column;
                gap: 15px;
            }

            & label {
                font-weight: bold;
                color: var(--marrom);
            }

            & input {
                padding: 10px;
                border: 1px solid #ccc;
                border-radius: 4px;
                width: 100%;
            }

            & button {
                padding: 10px;
                background-color: var(--marrom);
                color: var(--dourado);
                border: none;
                border-radius: 4px;
                cursor: pointer;
                font-weight: bold;
                transition: 450ms;

                &:hover {
                    transform: scale(1.05);
                }
            }
        }

        .cadastro {
            max-width: 400px;
            margin: 20px auto;
            background-color: #ececec;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            display: flex;
            flex-direction: column;
            gap: 15px;

            & h2 {
                text-align: center;
                color: var(--dourado);
                font-family: var(--fonte2);
            }

            & form {
                display: flex;
                flex-direction: column;
                gap: 15px;
            }

            & label {
                font-weight: bold;
                color: var(--marrom);
            }

            & input {
                padding: 10px;
                border: 1px solid #ccc;
                border-radius: 4px;
                width: 100%;
            }

            & button {
                padding: 10px;
                background-color: var(--marrom);
                color: var(--dourado);
                border: none;
                border-radius: 4px;
                cursor: pointer;
                font-weight: bold;
                transition: 450ms;

                &:hover {
                    transform: scale(1.05);
                }
            }
        }

        .perfil-logout {
            display: flex;
            gap: 10px;
            flex-direction: row;
            align-items: center;

            & #perfil {
                padding: 10px;
                background-color: var(--dourado);
                color: var(--marrom);
                border: none;
                border-radius: 4px;
                cursor: pointer;
                font-weight: bold;
                text-decoration: none;
            }
        }

        .alert-danger {
            background-color: #f8d7da;
            color: #721c24;
            padding: 10px;
            border-radius: 4px;
            margin: 20px auto;
            max-width: 400px;
            text-align: center;
        }

        .perfil-container {
            max-width: 600px;
            margin: 20px auto;
            background-color: #ececec;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);

            & h2 {
                text-align: center;
                color: var(--dourado);
                font-family: var(--fonte2);
            }

            & .perfil-info {
                display: flex;
                gap: 20px;
                align-items: center;

                & .perfil-foto {
                    width: 150px;
                    height: 150px;
                    border-radius: 50%;
                    object-fit: cover;
                }

                & .perfil-dados {
                    display: flex;
                    flex-direction: column;
                    gap: 10px;

                    & p {
                        font-size: 18px;
                        color: var(--marrom);
                    }
                }
            }
        }

        .img-usuario {
            display: flex;
            gap: 10px;
            align-items: center;

            & img {
                width: 40px;
                height: 40px;
                border-radius: 50%;
                object-fit: cover;
            }

            & li {
                color: var(--dourado);
                font-weight: bold;
            }
        }

        .inicio {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 80vh;
            background-image: url('../uploads/basilica.png');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            color: beige;

            & .home {
                width: 80%;

                & h1 {
                    font-size: 3rem;
                }

                & p {
                    width: 80%;
                    font-size: 1.2rem;
                    margin-top: 20px;
                    text-align: justify;
                    margin: auto;
                }
            }
        }

        footer {
            background-color: var(--marrom);
            color: var(--dourado);
            text-align: center;
            padding: 1rem;
            font-weight: bold;
        }
    </style>
</head>

<body>
    <header>
        <%- include('../partials/header') %>
    </header>

    <main>
        <%- body %>
    </main>

    <footer>
        <%- include('../partials/footer') %>
    </footer>
</body>

</html>